# Server/CORS
CORS_ALLOW_ORIGINS=http://localhost:5173
PORT=8000

# Neo4j (docker)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cookragNeo4j#2026

# MongoDB (docker)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=cookrag

# Ollama (local, not docker) - for embeddings only
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_TIMEOUT_S=120

# LLM Configuration (LangChain-based)
# Provider options: "qwen", "deepseek", "ollama"
LLM_PROVIDER=qwen

# Qwen/Tongyi Qianwen API (DashScope)
# Get API key from: https://dashscope.console.aliyun.com/
QWEN_API_KEY=your-qwen-api-key-here
QWEN_MODEL=qwen-turbo  # Options: qwen-turbo, qwen-plus, qwen-max

# DeepSeek API
# Get API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat

# Ollama LLM (local fallback)
OLLAMA_LLM_MODEL=qwen2.5:7b  # Pull with: ollama pull qwen2.5:7b

# Backend
APP_NAME=CookRag API

# Vector index name
VECTOR_INDEX_NAME=recipeEmbedding

# Auth
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRE_MINUTES=10080

